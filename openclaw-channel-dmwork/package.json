{
  "name": "openclaw-channel-dmwork",
  "version": "0.2.16",
  "description": "DMWork channel plugin for OpenClaw via WuKongIM WebSocket",
  "main": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "ws": "^8.16.0",
    "wukongimjssdk": "^1.3.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "openclaw": "2026.3.1",
    "typescript": "^5.9.3"
  },
  "openclaw": {
    "id": "openclaw-channel-dmwork",
    "type": "channel",
    "extensions": [
      "index.ts"
    ]
  },
  "bundledDependencies": [
    "wukongimjssdk"
  ]
