{
  "name": "openclaw-channel-dmwork",
  "version": "0.3.5",
  "description": "DMWork channel plugin for OpenClaw via WuKongIM WebSocket",
  "main": "index.ts",
  "type": "module",
  "files": [
    "index.ts",
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "crypto-js": "^4.2.0",
    "curve25519-js": "^0.0.4",
    "md5-typescript": "^1.0.5",
    "ws": "^8.16.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.2.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/ws": "^8.5.10",
    "openclaw": "2026.3.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "openclaw": {
    "id": "openclaw-channel-dmwork",
    "type": "channel",
    "extensions": [
      "index.ts"
    ]
  },
  "bundledDependencies": [
    "crypto-js",
    "curve25519-js",
    "md5-typescript"
  ],
  "bundleDependencies": [
    "crypto-js",
    "curve25519-js",
    "md5-typescript"
  ]
}